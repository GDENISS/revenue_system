# ============================================================
# Revenue System — docker-compose configuration
# Copy to .env next to docker-compose.yml, then fill in values.
#   cp .env.example .env
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=revenue
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=revenue_db

# ── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Host ports ──────────────────────────────────────────────
# Pick ports that are FREE on the VPS (`docker ps` shows what's taken).
API_PORT=8081
WEB_PORT=3000

# ── Public URLs (replace <VPS_IP> with your Contabo IP or domain) ──
# URL the browser uses to reach the API — baked into the frontend at build time.
API_PUBLIC_URL=http://<VPS_IP>:8081
# URL where colleagues open the app; also used for the Paystack callback.
WEB_PUBLIC_URL=http://<VPS_IP>:3000
# Origins allowed to call the API (comma-separated). Usually = WEB_PUBLIC_URL.
ALLOWED_ORIGINS=http://<VPS_IP>:3000

# ── ArcGIS (optional — app runs without it; sync just stays idle) ──
ARCGIS_BASE_URL=https://www.arcgis.com
ARCGIS_CLIENT_ID=
ARCGIS_CLIENT_SECRET=
ARCGIS_PARCEL_LAYER_ID=
ARCGIS_BUSINESS_LAYER_ID=
ARCGIS_MARKET_STALL_LAYER_ID=
ARCGIS_SYNC_INTERVAL_MINUTES=15
ARCGIS_ADMIN_USERNAMES=
# Frontend OAuth app id + anonymous basemap key (both optional)
ARCGIS_APP_ID=
ARCGIS_API_KEY=

# ── Branding ────────────────────────────────────────────────
COUNTY_NAME=NAIROBI CITY COUNTY
COUNTY_LOGO_URL=

# ── Paystack (test keys are fine for the testing phase) ─────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_NOREPLY_DOMAIN=revenue.local
