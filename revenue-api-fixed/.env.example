# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/revenue_db

# ── Server ───────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of origins allowed to call this API from a browser.
# Leave unset to allow all origins (development only).
ALLOWED_ORIGINS=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── ArcGIS ───────────────────────────────────────────────────
ARCGIS_BASE_URL=https://www.arcgis.com
ARCGIS_CLIENT_ID=your_arcgis_client_id
ARCGIS_CLIENT_SECRET=your_arcgis_client_secret
ARCGIS_PARCEL_LAYER_ID=your_parcel_feature_layer_id
ARCGIS_BUSINESS_LAYER_ID=your_business_feature_layer_id
ARCGIS_MARKET_STALL_LAYER_ID=your_market_stall_feature_layer_id
ARCGIS_SYNC_INTERVAL_MINUTES=15

# Comma-separated ArcGIS usernames that should be auto-provisioned as admin
# the first time they sign in. Useful for bootstrapping a fresh database.
ARCGIS_ADMIN_USERNAMES=

# ── App ──────────────────────────────────────────────────────
COUNTY_NAME= NAIROBI CITY COUNTY
COUNTY_LOGO_URL=https://your-county-website.go.ke/logo.png

# ── Paystack ─────────────────────────────────────────────────
# Get keys from https://dashboard.paystack.com → Settings → API Keys & Webhooks.
# SECRET key never goes to the frontend — only this backend calls Paystack.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where Paystack sends the taxpayer after they finish checkout. The frontend
# notices view reads ?reference=... from this URL to call the verify endpoint.
PAYSTACK_CALLBACK_URL=http://localhost:3000/?view=bulk&paystack_callback=1
# Used to synthesize a no-reply email when the taxpayer record has none.
PAYSTACK_NOREPLY_DOMAIN=revenue.local
